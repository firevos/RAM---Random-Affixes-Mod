<configs>
    <insertAfter xpath="/lootcontainers/lootgroup[@name='groupWeaponsAllScaledNoParts']">
        <lootgroup name="ArmorWeaponsMagicFind">
            <item group="groupAllArmor"/>
            <item group="groupWeaponsAllScaledNoParts"/>
        </lootgroup>
    </insertAfter>

    <append xpath="/lootcontainers/lootgroup[@name='groupReinforcedChestT2']">
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="2"/>
        </item>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupInfestedT2']">
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="2"/>
        </item>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupReinforcedChestT3']">
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="2"/>
        </item>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupInfestedT3']">
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="2"/>
        </item>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupHardenedChestT4']">
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="2"/>
        </item>
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="5"/>
        </item>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupInfestedT4']">
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="2"/>
        </item>
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="5"/>
        </item>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupHardenedChestT5']">
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="2"/>
        </item>
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="5"/>
        </item>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupInfestedT5']">
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="2"/>
        </item>
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="5"/>
        </item>
    </append>

    <append xpath="/lootcontainers/lootgroup[@name='groupHiddenStash']">
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="2"/>
        </item>
        <item group="ArmorWeaponsMagicFind" count="1">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="5"/>
        </item>
    </append>

    <insertAfter xpath="/lootcontainers/lootgroup[@name='groupAmmoRocket']">
        <lootgroup name="groupAffixTokens">
            <item name="affixRerollToken" count="1" loot_prob_template="high"/>
            <item name="affixExtractionToken" count="1" loot_prob_template="med"/>
            <item name="affixSwapToken" count="1" loot_prob_template="med"/>
            <item name="affixUpgradeToken" count="1" loot_prob_template="low"/>
            <item name="affixUnlockToken" count="1" loot_prob_template="veryLow"/>
        </lootgroup>
        <lootgroup name="groupJackOfAllTradesArmors">
            <item name="armorPrimitiveHelmetUnique"/>
            <item name="armorPrimitiveOutfitUnique"/>
            <item name="armorPrimitiveGlovesUnique"/>
            <item name="armorPrimitiveBootsUnique"/>
        </lootgroup>
    </insertAfter>

    <insertBefore xpath="/lootcontainers/lootprobtemplates/lootprobtemplate[@name='veryLowDelayed']">
        <lootprobtemplate name="ramVeryVeryLow">
            <loot level="0,999999" prob=".005"/>
        </lootprobtemplate>
    </insertBefore>

    <!-- Affix Tokens -->
    <append xpath="/lootcontainers/lootgroup[@name='groupShoppingCart']">
        <item group="groupAffixTokens" loot_prob_template="veryLowDelayed" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupSafeBooks']">
        <item group="groupAffixTokens" loot_prob_template="veryLowDelayed" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupCampingTents']">
        <item name="affixRerollToken" count="1" loot_prob_template="ramVeryVeryLow" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupJunk']">
        <item name="affixRerollToken" count="1" loot_prob_template="ramVeryVeryLow" force_prob="true">
            <requirement class="Progression" name="perkMagicFind" operation="GTE" value="5"/>
        </item>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupPurse']">
        <item name="affixRerollToken" count="1" loot_prob_template="veryLowDelayed" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootcontainer[@name='cashRegister']">
        <item group="groupAffixTokens" loot_prob_template="veryLowDelayed" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupZpackStrong']">
        <item group="groupAffixTokens" loot_prob_template="veryLow" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupZpackBoss']">
        <item group="groupAffixTokens" loot_prob_template="low" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupPoliceCarBonus']">
        <item name="affixRerollToken" loot_prob_template="low" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupHiddenStash']">
        <item group="groupAffixTokens" loot_prob_template="veryLowDelayed" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupValuablesExtraLarge']">
        <item group="groupAffixTokens" loot_prob_template="low" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootcontainer[@name='atmLoot']">
        <item group="groupAffixTokens" loot_prob_template="veryLowDelayed" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupReinforcedChestT3']">
        <item name="affixRerollToken" count="1" loot_prob_template="veryLowDelayed"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupHardenedChestT4']">
        <item group="groupAffixTokens" loot_prob_template="veryLow" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupHardenedChestT5']">
        <item group="groupAffixTokens" loot_prob_template="low" force_prob="true"/>
    </append>

    <!-- For Quest rewards -->
    <insertAfter xpath="/lootcontainers/lootgroup[@name='groupQuestT3MeleeMods']">
        <lootgroup name="groupQuestT5TokenBundle" count="all">
            <item name="questRewardTokenBundle"/>
        </lootgroup>

        <lootgroup name="groupQuestT3Token" count="all">
            <item name="affixRerollToken"/>
        </lootgroup>
        <lootgroup name="groupQuestT4Token" count="all">
            <item name="affixExtractionToken"/>
        </lootgroup>
        <lootgroup name="groupQuestT4SwapToken" count="all">
            <item name="affixSwapToken"/>
        </lootgroup>
        <lootgroup name="groupQuestT5Token" count="all">
            <item name="affixUpgradeToken"/>
        </lootgroup>
        <lootgroup name="groupQuestT6Token" count="all">
            <item name="affixUnlockToken"/>
        </lootgroup>
        <lootgroup name="groupQuestT6AscensionToken" count="all">
            <item name="affixAscensionToken"/>
        </lootgroup>
    </insertAfter>

    <!-- Templates for Uniques -->
    <insertBefore xpath="/lootcontainers/lootprobtemplates/lootprobtemplate[@name='veryLowDelayed']">
        <lootprobtemplate name="uniqueT0">
            <loot level="0,999999" prob=".01"/>
        </lootprobtemplate>
        <lootprobtemplate name="uniqueT1">
            <loot level="0,28" prob="0"/>
            <loot level="29,999999" prob=".01"/>
        </lootprobtemplate>
        <lootprobtemplate name="uniqueT2">
            <loot level="0,68" prob="0"/>
            <loot level="69,999999" prob=".01"/>
        </lootprobtemplate>
        <lootprobtemplate name="uniqueT3">
            <loot level="0,98" prob="0"/>
            <loot level="99,999999" prob=".005"/>
        </lootprobtemplate>
    </insertBefore>

    <insertAfter xpath="/lootcontainers/lootqualitytemplates/lootqualitytemplate[@name='qualQ1Template']">
        <lootqualitytemplate name="qualQ7Template">
            <qualitytemplate level="1,999999" default_quality="7">
                <loot quality="7" prob="1"/>
            </qualitytemplate>
        </lootqualitytemplate>
    </insertAfter>

    <!-- Uniques -->
    <append xpath="/lootcontainers/lootgroup[@name='groupToilet02']">
        <item name="meleeWpnBladeT1HuntingKnifeUnique" count="1" loot_prob_template="uniqueT0"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupZpackPlague']">
        <item name="gunRifleT1HuntingRifleUnique" count="1" loot_prob_template="uniqueT1" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupDesks02']">
        <item name="meleeWpnClubT1BaseballBatUnique" count="1" loot_prob_template="uniqueT1"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupZpackSoldier']">
        <item name="gunMGT2TacticalARUnique" count="1" loot_prob_template="uniqueT2" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupGunSafeSecure']">
        <item name="gunMGT3M60Unique" count="1" loot_prob_template="uniqueT3" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupPurse']">
        <item name="gunHandgunT3DesertVultureUnique" count="1" loot_prob_template="uniqueT3" force_prob="true"/>
    </append>
    <append xpath="/lootcontainers/lootgroup[@name='groupBackpacks']">
        <item group="groupJackOfAllTradesArmors" count="1" loot_prob_template="uniqueT0" force_prob="true"/>
    </append>
</configs>
