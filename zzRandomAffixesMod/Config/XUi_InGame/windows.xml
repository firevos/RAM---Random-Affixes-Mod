<configs>
    <set xpath="/windows/window[@name='windowAssemble']/rect[@name='content']//grid[@name='cosmeticparts']/preceding-sibling::rect[@name='header'][1]/@pos">
        -387, 46
    </set>

    <set xpath="/windows/window[@name='windowAssemble']/rect[@name='content']//grid[@name='cosmeticparts']/preceding-sibling::rect[@name='header'][1]/sprite/@sprite">
        ui_affixes_icon
    </set>

    <set xpath="/windows/window[@name='windowAssemble']/rect[@name='content']//grid[@name='cosmeticparts']/@rows">
        10
    </set>

    <set xpath="/windows/window[@name='windowAssemble']/rect[@name='content']//grid[@name='cosmeticparts']/@pos">
        -384,-3
    </set>

    <set xpath="/windows/window[@name='windowAssemble']/rect[@name='content']//grid[@name='parts']/preceding-sibling::rect[@name='header'][1]/@pos">
        0,-230
    </set>

    <set xpath="/windows/window[@name='windowAssemble']/rect[@name='content']//grid[@name='parts']/@pos">
        3,-279
    </set>

    <set xpath="/windows/window[@name='windowAssemble']/rect[@name='content']//grid[@name='cosmeticparts']/preceding-sibling::rect[@name='header'][1]/label/@text_key">
        xuiAffixes
    </set>

    <insertBefore xpath="/windows/window[@name='HUDRightStatBars']/grid[@name='hud']">
        <rect name="KillsUpgradesPanel" pos="-194,55" width="188" height="46" side="right" controller="XUiC_ActiveItemKillsUpgrades,WeaponAffixesProject" visible="{kuvisible}">
            <sprite depth="3" pos="3,0" sprite="ui_game_popup" height="46" width="182" />
            <label depth="6" name="TextContent" pos="112,-24" font_size="28" color="[white]" justify="right" pivot="right" text="{kills}/{nextUpgrade}" width="120" height="35"/>
            <sprite depth="4" sprite="ui_kill_count_icon" size="35,35" pos="148,-24" pivot="center" foregroundlayer="true" />
        </rect>
    </insertBefore>

    <append xpath="/windows/window[@name='CharacterFrameWindow']//rect[@controller='TabSelectorTab' and @tab_key='stats2']">
        <rect name="ramHeldWeaponKills" pos="0,-510" width="327" height="30" controller="XUiC_ActiveItemKillsUpgrades,WeaponAffixesProject" visible="{kustatsvisible}">
            <sprite depth="8" sprite="menu_empty3px" height="33" color="[black]" type="sliced" fillcenter="false" />
            <sprite depth="1" color="[darkGrey]" type="sliced" />
            <label depth="3" pos="10,-17" width="200" height="27" font_size="26" text_key="ramHeldWeaponKills" pivot="left" justify="left" color="[white]" />
            <label depth="3" pos="320,-17" width="105" height="27" font_size="26" text="{kills}/{nextUpgrade}" justify="right" color="[selectedColor]" pivot="right" />
        </rect>
    </append>

    <append xpath="/windows">
        <window name="windowCombineAffixChooser" width="153" height="796" panel="Right" cursor_area="true" controller="XUiC_CombineAffixChooser,WeaponAffixesProject">
            <rect style="header.panel">
                <headerbg />
                <sprite style="header.icon" sprite="ui_affixes_icon"/>
                <label style="header.name" text="AFFIXES" text_key="xuiAffixes"/>
            </rect>

            <rect name="content" pos="0,-46" height="750" width="153">
                <sprite depth="2" name="backgroundMain" sprite="menu_empty3px" pos="0,1" width="153" height="750" color="[black]" type="sliced" fillcenter="false" />
                <sprite name="background" color="[darkGrey]" pos="0,1" type="sliced"/>

                <grid name="itemAAffixes" rows="10" cols="1" pos="3,-3" cell_width="75" cell_height="75">
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="0" prefix_id="A0"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="1" prefix_id="A1"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="2" prefix_id="A2"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="3" prefix_id="A3"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="4" prefix_id="A4"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="5" prefix_id="A5"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="6" prefix_id="A6"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="7" prefix_id="A7"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="8" prefix_id="A8"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="9" prefix_id="A9"/>
                </grid>

                <grid name="itemBAffixes" rows="10" cols="1" pos="78,-3" cell_width="75" cell_height="75">
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="0" prefix_id="B0"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="1" prefix_id="B1"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="2" prefix_id="B2"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="3" prefix_id="B3"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="4" prefix_id="B4"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="5" prefix_id="B5"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="6" prefix_id="B6"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="7" prefix_id="B7"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="8" prefix_id="B8"/>
                    <item_stack controller="XUiC_CombineAffixStack,WeaponAffixesProject" cell_size="75" allow_dropping="false" repeat_i="9" prefix_id="B9"/>
                </grid>

                <rect name="combineButton" controller="XUiC_CombineAffixButton,WeaponAffixesProject" pos="0,-750" width="153" height="42" style="press, hover" sprite="menu_empty3px" type="sliced" color="[black]" sound="[craft_click]">
                    <sprite name="buttonBorder" depth="4" pos="0,0" width="153" height="42" sprite="menu_empty3px" type="sliced" color="[black]" fillcenter="false" />
                    <button name="button" pos="3,-3" width="147" height="36" depth="5" style="press, hover" sprite="menu_empty3px" type="sliced" defaultcolor="82,75,58,255" hovercolor="124,111,78,255" selectedcolor="150,128,80,255" hoverscale="1.0" sound="[craft_click]"/>
                    <label name="label" depth="6" pos="76,-21" width="153" height="42" text="COMBINE" text_key="xuiCombine" font_size="26" justify="center" pivot="center" color="[white]" effect="outline"/>
                </rect>
            </rect>
        </window>
    </append>
</configs>
